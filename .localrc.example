# Machine-local shell configuration
# Copy this to ~/.localrc and adjust to your setup.
# Sourced by .zshrc if present. Not tracked by yadm.

# Workspace directory for the ws() function
export WORKSPACE="$HOME/workspace"

# Machine-specific exports
# export DATASETS=~/Datasets

# Project aliases
# alias myproject="cd $HOME/workspace/myproject"

# Machine-specific PATH additions
# PATH=${PATH}:$HOME/some/local/tool
# export PATH=$WORKSPACE/some_scripts:$PATH

# Tool-specific setup (e.g. LM Studio, bun, nvm, cargo, etc.)
# export PATH="$PATH:$HOME/.lmstudio/bin"
# export BUN_INSTALL="$HOME/.bun"
# export PATH="$BUN_INSTALL/bin:$PATH"
# [ -s "$HOME/.bun/_bun" ] && source "$HOME/.bun/_bun"
